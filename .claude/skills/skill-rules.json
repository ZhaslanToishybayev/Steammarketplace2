{
    "version": "1.0",
    "description": "Steam Marketplace Claude Code - Skill activation triggers for Steam Marketplace project",
    "skills": {
        "skill-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-skill for creating and managing Claude Code skills",
            "promptTriggers": {
                "keywords": [
                    "skill system",
                    "create skill",
                    "add skill",
                    "skill triggers",
                    "skill rules",
                    "hook system",
                    "skill development",
                    "skill-rules.json"
                ],
                "intentPatterns": [
                    "(how do|how does|explain).*?skill",
                    "(create|add|modify|build).*?skill",
                    "skill.*?(work|trigger|activate|system)"
                ]
            }
        },
        "steam-marketplace-backend": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Steam Marketplace backend development patterns for Node.js/Express/JavaScript with MongoDB/Mongoose",
            "promptTriggers": {
                "keywords": [
                    "backend",
                    "route",
                    "routing",
                    "express",
                    "API",
                    "endpoint",
                    "middleware",
                    "validation",
                    "mongoose",
                    "MongoDB",
                    "steam",
                    "steam integration",
                    "steam bot",
                    "trade offer",
                    "marketplace",
                    "SteamUser",
                    "TradeOfferManager",
                    "SteamStrategy",
                    "passport-steam",
                    "socket.io"
                ],
                "intentPatterns": [
                    "(create|add|implement|build).*?(route|endpoint|API|service)",
                    "(fix|handle|debug).*?(steam|trade|bot|error)",
                    "(add|implement).*?(middleware|validation|steam.*?auth)",
                    "(organize|structure|refactor).*?(backend|service|API)",
                    "(how to|best practice).*?(steam|trade|marketplace|mongoose)",
                    "(implement|add|setup).*?(steam|bot|trade.*?offer)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "routes/**/*.js",
                    "models/**/*.js",
                    "services/**/*.js",
                    "middleware/**/*.js",
                    "app.js",
                    "server.js"
                ],
                "pathExclusions": [
                    "**/*.test.js",
                    "**/*.spec.js",
                    "node_modules/**/*",
                    ".claude/**/*"
                ],
                "contentPatterns": [
                    "router\\.",
                    "app\\.(get|post|put|delete|patch)",
                    "require.*mongoose",
                    "module\\.exports",
                    "SteamUser",
                    "TradeOfferManager",
                    "SteamStrategy",
                    "passport\\.use",
                    "steam-bot",
                    "steam-tradeoffer",
                    "socket\\.io"
                ]
            }
        },
        "steam-marketplace-frontend": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "Frontend development for Steam Marketplace interface",
            "promptTriggers": {
                "keywords": [
                    "frontend",
                    "UI",
                    "interface",
                    "html",
                    "bootstrap",
                    "socket.io client",
                    "static files",
                    "public",
                    "templates",
                    "express.static",
                    "marketplace UI"
                ],
                "intentPatterns": [
                    "(create|add|build).*?(HTML|UI|frontend|interface)",
                    "(update|modify).*?(public|static|templates)",
                    "(add|implement).*?(socket.*?client|WebSocket)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "public/**/*.html",
                    "templates/**/*.ejs",
                    "templates/**/*.html",
                    "static/**/*"
                ],
                "pathExclusions": [
                    "node_modules/**/*"
                ],
                "contentPatterns": [
                    "<!DOCTYPE",
                    "bootstrap",
                    "socket\\.io",
                    "express\\.static"
                ]
            }
        },
        "steam-integration": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "critical",
            "description": "Steam API integration, bot management, and trade offer handling",
            "promptTriggers": {
                "keywords": [
                    "steam bot",
                    "steam integration",
                    "steam API",
                    "trade offer",
                    "trade validation",
                    "steam auth",
                    "steam inventory",
                    "SteamUser",
                    "TradeOfferManager",
                    "steam guard",
                    "steamcommunity"
                ],
                "intentPatterns": [
                    "(create|add|setup).*?(steam.*?bot|steam.*?integration)",
                    "(fix|debug|handle).*?(steam|trade.*?offer|bot)",
                    "(implement|add).*?(steam.*?auth|steam.*?trade)",
                    "(validate|verify).*?(trade|steam.*?item|steam.*?offer)",
                    "(how to|best practice).*?(steam.*?API|steam.*?bot|trade)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "routes/steam.js",
                    "services/*steam*.js",
                    "**/*bot*.js"
                ],
                "pathExclusions": [
                    "node_modules/**/*"
                ],
                "contentPatterns": [
                    "SteamUser",
                    "TradeOfferManager",
                    "steam-user",
                    "steam-tradeoffer",
                    "steamcommunity",
                    "steamGuard",
                    "sharedSecret",
                    "identitySecret"
                ]
            }
        },
        "marketplace-commerce": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Marketplace commerce features: listings, payments, transactions",
            "promptTriggers": {
                "keywords": [
                    "marketplace",
                    "listing",
                    "purchase",
                    "sale",
                    "payment",
                    "stripe",
                    "wallet",
                    "balance",
                    "transaction",
                    "currency",
                    "price",
                    "seller",
                    "buyer"
                ],
                "intentPatterns": [
                    "(create|add).*?(listing|market.*?listing)",
                    "(implement|add).*?(purchase|sale|payment)",
                    "(fix|handle).*?(transaction|payment|wallet)",
                    "(validate|verify).*?(listing|price|transaction)",
                    "(how to|best practice).*?(marketplace|commerce|payment)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "routes/marketplace.js",
                    "routes/payments.js",
                    "models/MarketListing.js",
                    "models/Transaction.js",
                    "services/*marketplace*.js"
                ],
                "contentPatterns": [
                    "MarketListing",
                    "Transaction",
                    "marketplace.*listing",
                    "stripe",
                    "wallet.*balance",
                    "pendingBalance"
                ]
            }
        },
        "mongoose-patterns": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Mongoose ODM patterns for MongoDB",
            "promptTriggers": {
                "keywords": [
                    "mongoose",
                    "MongoDB",
                    "schema",
                    "model",
                    "database",
                    "collection",
                    "findOne",
                    "findById",
                    "save",
                    "populate",
                    "aggregate"
                ],
                "intentPatterns": [
                    "(create|define).*?(schema|model)",
                    "(query|fetch).*?(database|MongoDB|mongoose)",
                    "(add|implement).*?(mongoose|model.*?method)",
                    "(optimize|fix).*?(mongoose|query|database)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "models/**/*.js"
                ],
                "contentPatterns": [
                    "require.*mongoose",
                    "mongoose\\.Schema",
                    "\\.model\\(",
                    "findOne",
                    "findById",
                    "\\.populate\\(",
                    "new mongoose\\.Schema"
                ]
            }
        },
        "route-tester": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Testing authenticated API routes with Steam/JWT auth",
            "promptTriggers": {
                "keywords": [
                    "test route",
                    "test endpoint",
                    "test API",
                    "route testing",
                    "API testing",
                    "authenticated route",
                    "JWT testing",
                    "steam auth testing",
                    "test with auth"
                ],
                "intentPatterns": [
                    "(test|debug|verify).*?(route|endpoint|API)",
                    "(how to|how do I).*?test.*?(route|endpoint|API)",
                    "test.*?(authenticated|auth|JWT|steam)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "routes/**/*.js",
                    "test-*.js"
                ],
                "contentPatterns": [
                    "router\\.(get|post|put|delete|patch)",
                    "app\\.(get|post|put|delete|patch)",
                    "SteamStrategy",
                    "passport.*authenticate"
                ]
            }
        }
    },
    "notes": {
        "enforcement_types": {
            "suggest": "Skill suggestion appears but doesn't block execution",
            "block": "Requires skill to be used before proceeding (guardrail)",
            "warn": "Shows warning but allows proceeding"
        },
        "priority_levels": {
            "critical": "Highest - Always trigger when matched",
            "high": "Important - Trigger for most matches",
            "medium": "Moderate - Trigger for clear matches",
            "low": "Optional - Trigger only for explicit matches"
        },
        "steam_marketplace_config": {
            "project_structure": "Express.js + MongoDB + Steam API",
            "database": "MongoDB with Mongoose ODM",
            "auth": "Steam OAuth via Passport.js + JWT",
            "steam_libraries": "steam-user, steam-tradeoffer-manager, steamcommunity",
            "real_time": "Socket.io"
        }
    }
}
