{
    "version": "1.0",
    "description": "Steam Marketplace Claude Code - Skill activation triggers for Steam Marketplace project",
    "skills": {
        "skill-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-skill for creating and managing Claude Code skills",
            "promptTriggers": {
                "keywords": [
                    "skill system",
                    "create skill",
                    "add skill",
                    "skill triggers",
                    "skill rules",
                    "hook system",
                    "skill development",
                    "skill-rules.json"
                ],
                "intentPatterns": [
                    "(how do|how does|explain).*?skill",
                    "(create|add|modify|build).*?skill",
                    "skill.*?(work|trigger|activate|system)"
                ]
            }
        },
        "steam-marketplace-backend": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Steam Marketplace backend development patterns for Node.js/Express/JavaScript with MongoDB/Mongoose",
            "promptTriggers": {
                "keywords": [
                    "backend",
                    "route",
                    "routing",
                    "express",
                    "API",
                    "endpoint",
                    "middleware",
                    "validation",
                    "mongoose",
                    "MongoDB",
                    "steam",
                    "steam integration",
                    "steam bot",
                    "trade offer",
                    "marketplace",
                    "SteamUser",
                    "TradeOfferManager",
                    "SteamStrategy",
                    "passport-steam",
                    "socket.io"
                ],
                "intentPatterns": [
                    "(create|add|implement|build).*?(route|endpoint|API|service)",
                    "(fix|handle|debug).*?(steam|trade|bot|error)",
                    "(add|implement).*?(middleware|validation|steam.*?auth)",
                    "(organize|structure|refactor).*?(backend|service|API)",
                    "(how to|best practice).*?(steam|trade|marketplace|mongoose)",
                    "(implement|add|setup).*?(steam|bot|trade.*?offer)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "routes/**/*.js",
                    "models/**/*.js",
                    "services/**/*.js",
                    "middleware/**/*.js",
                    "app.js",
                    "server.js"
                ],
                "pathExclusions": [
                    "**/*.test.js",
                    "**/*.spec.js",
                    "node_modules/**/*",
                    ".claude/**/*"
                ],
                "contentPatterns": [
                    "router\\.",
                    "app\\.(get|post|put|delete|patch)",
                    "require.*mongoose",
                    "module\\.exports",
                    "SteamUser",
                    "TradeOfferManager",
                    "SteamStrategy",
                    "passport\\.use",
                    "steam-bot",
                    "steam-tradeoffer",
                    "socket\\.io"
                ]
            }
        },
        "steam-marketplace-frontend": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "Frontend development for Steam Marketplace (React + Vite + i18n + Dark/Light themes)",
            "promptTriggers": {
                "keywords": [
                    "frontend",
                    "React",
                    "UI",
                    "interface",
                    "component",
                    "jsx",
                    "tsx",
                    "Vite",
                    "dark theme",
                    "light theme",
                    "i18n",
                    "internationalization",
                    "theme",
                    "router",
                    "socket.io client",
                    "marketplace UI",
                    "ListingCard",
                    "Header"
                ],
                "intentPatterns": [
                    "(create|add|build).*?(React|component|UI|frontend)",
                    "(update|modify).*?(frontend|component|theme)",
                    "(add|implement).*?(theme|i18n|router|WebSocket)",
                    "(style|css|theme).*?(component|UI)",
                    "(optimize|reduce).*?(bundle|size)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "frontend/src/**/*.{js,jsx,ts,tsx}",
                    "frontend/src/**/**/*.{js,jsx,ts,tsx}",
                    "frontend/package.json",
                    "frontend/vite.config.js"
                ],
                "pathExclusions": [
                    "frontend/node_modules/**/*",
                    "**/*.test.{js,jsx,ts,tsx}",
                    "**/*.spec.{js,jsx,ts,tsx}"
                ],
                "contentPatterns": [
                    "import.*from.*react",
                    "useState|useEffect",
                    "ThemeContext",
                    "i18n",
                    "socket\\.io",
                    "function.*Component",
                    "const.*=.*\\(\\) =>"
                ]
            }
        },
        "steam-integration": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "critical",
            "description": "Steam API integration, bot management, and trade offer handling",
            "promptTriggers": {
                "keywords": [
                    "steam bot",
                    "steam integration",
                    "steam API",
                    "trade offer",
                    "trade validation",
                    "steam auth",
                    "steam inventory",
                    "SteamUser",
                    "TradeOfferManager",
                    "steam guard",
                    "steamcommunity"
                ],
                "intentPatterns": [
                    "(create|add|setup).*?(steam.*?bot|steam.*?integration)",
                    "(fix|debug|handle).*?(steam|trade.*?offer|bot)",
                    "(implement|add).*?(steam.*?auth|steam.*?trade)",
                    "(validate|verify).*?(trade|steam.*?item|steam.*?offer)",
                    "(how to|best practice).*?(steam.*?API|steam.*?bot|trade)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "routes/steam.js",
                    "services/*steam*.js",
                    "**/*bot*.js"
                ],
                "pathExclusions": [
                    "node_modules/**/*"
                ],
                "contentPatterns": [
                    "SteamUser",
                    "TradeOfferManager",
                    "steam-user",
                    "steam-tradeoffer",
                    "steamcommunity",
                    "steamGuard",
                    "sharedSecret",
                    "identitySecret"
                ]
            }
        },
        "marketplace-commerce": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Marketplace commerce features: listings, payments, transactions",
            "promptTriggers": {
                "keywords": [
                    "marketplace",
                    "listing",
                    "purchase",
                    "sale",
                    "payment",
                    "stripe",
                    "wallet",
                    "balance",
                    "transaction",
                    "currency",
                    "price",
                    "seller",
                    "buyer"
                ],
                "intentPatterns": [
                    "(create|add).*?(listing|market.*?listing)",
                    "(implement|add).*?(purchase|sale|payment)",
                    "(fix|handle).*?(transaction|payment|wallet)",
                    "(validate|verify).*?(listing|price|transaction)",
                    "(how to|best practice).*?(marketplace|commerce|payment)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "routes/marketplace.js",
                    "routes/payments.js",
                    "models/MarketListing.js",
                    "models/Transaction.js",
                    "services/*marketplace*.js"
                ],
                "contentPatterns": [
                    "MarketListing",
                    "Transaction",
                    "marketplace.*listing",
                    "stripe",
                    "wallet.*balance",
                    "pendingBalance"
                ]
            }
        },
        "mongoose-patterns": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Mongoose ODM patterns for MongoDB",
            "promptTriggers": {
                "keywords": [
                    "mongoose",
                    "MongoDB",
                    "schema",
                    "model",
                    "database",
                    "collection",
                    "findOne",
                    "findById",
                    "save",
                    "populate",
                    "aggregate"
                ],
                "intentPatterns": [
                    "(create|define).*?(schema|model)",
                    "(query|fetch).*?(database|MongoDB|mongoose)",
                    "(add|implement).*?(mongoose|model.*?method)",
                    "(optimize|fix).*?(mongoose|query|database)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "models/**/*.js"
                ],
                "contentPatterns": [
                    "require.*mongoose",
                    "mongoose\\.Schema",
                    "\\.model\\(",
                    "findOne",
                    "findById",
                    "\\.populate\\(",
                    "new mongoose\\.Schema"
                ]
            }
        },
        "route-tester": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Testing authenticated API routes with Steam/JWT auth",
            "promptTriggers": {
                "keywords": [
                    "test route",
                    "test endpoint",
                    "test API",
                    "route testing",
                    "API testing",
                    "authenticated route",
                    "JWT testing",
                    "steam auth testing",
                    "test with auth"
                ],
                "intentPatterns": [
                    "(test|debug|verify).*?(route|endpoint|API)",
                    "(how to|how do I).*?test.*?(route|endpoint|API)",
                    "test.*?(authenticated|auth|JWT|steam)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "routes/**/*.js",
                    "test-*.js"
                ],
                "contentPatterns": [
                    "router\\.(get|post|put|delete|patch)",
                    "app\\.(get|post|put|delete|patch)",
                    "SteamStrategy",
                    "passport.*authenticate"
                ]
            }
        },
        "testing-suite": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Comprehensive testing suite: Jest, Playwright, Artillery, MongoDB Memory Server",
            "promptTriggers": {
                "keywords": [
                    "test",
                    "testing",
                    "jest",
                    "playwright",
                    "e2e",
                    "unit test",
                    "integration test",
                    "artillery",
                    "load test",
                    "performance test",
                    "mongodb-memory-server",
                    "coverage",
                    "test runner",
                    "mock",
                    "nock"
                ],
                "intentPatterns": [
                    "(write|create|add).*?test",
                    "(setup|configure).*?(jest|playwright|testing)",
                    "(run|execute).*?test",
                    "(test|verify).*?(performance|load|e2e|unit|integration)",
                    "(increase|improve).*?test.*?coverage"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "tests/**/*.js",
                    "tests/**/*.spec.js",
                    "jest.config.js",
                    "playwright.config.js",
                    "artillery.yml",
                    "package.json"
                ],
                "pathExclusions": [
                    "node_modules/**/*"
                ],
                "contentPatterns": [
                    "describe\\(",
                    "test\\(",
                    "expect\\(",
                    "beforeEach|afterEach",
                    "@playwright/test",
                    "artillery"
                ]
            }
        },
        "deployment-vercel-pskz": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "Deployment strategies: Vercel Pro current, migration to ps.kz",
            "promptTriggers": {
                "keywords": [
                    "deploy",
                    "deployment",
                    "vercel",
                    "ps.kz",
                    "CI/CD",
                    "github actions",
                    "docker",
                    "nginx",
                    "load balancer",
                    "blue-green deployment",
                    "migration",
                    "staging",
                    "production"
                ],
                "intentPatterns": [
                    "(deploy|deploy).*?(vercel|pskz|production)",
                    "(setup|configure).*?(CI/CD|github.*?actions)",
                    "(migrate|move).*?(vercel.*?pskz|hosting)",
                    "(setup|configure).*?(nginx|load.*?balancer)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    ".github/workflows/**/*",
                    "Dockerfile*",
                    "docker-compose*.yml",
                    "nginx/**/*",
                    "k8s/**/*",
                    "vercel.json"
                ],
                "pathExclusions": [
                    "node_modules/**/*"
                ],
                "contentPatterns": [
                    "github.*?workflows",
                    "vercel",
                    "docker.*?build",
                    "nginx.*?config",
                    "pskz"
                ]
            }
        }
    },
    "notes": {
        "enforcement_types": {
            "suggest": "Skill suggestion appears but doesn't block execution",
            "block": "Requires skill to be used before proceeding (guardrail)",
            "warn": "Shows warning but allows proceeding"
        },
        "priority_levels": {
            "critical": "Highest - Always trigger when matched",
            "high": "Important - Trigger for most matches",
            "medium": "Moderate - Trigger for clear matches",
            "low": "Optional - Trigger only for explicit matches"
        },
        "steam_marketplace_config": {
            "project_structure": "Express.js + MongoDB + Steam API + React/Vite frontend",
            "database": "MongoDB with Mongoose ODM",
            "auth": "Steam OAuth via Passport.js + JWT",
            "steam_libraries": "steam-user, steam-tradeoffer-manager, steamcommunity",
            "real_time": "Socket.io",
            "frontend": "React 18 + Vite + i18next + Dark/Light themes",
            "testing": "Jest + Playwright + Artillery + MongoDB Memory Server",
            "deployment": "Vercel Pro (current) → ps.kz (target)",
            "ci_cd": "GitHub Actions"
        }
    }
}
