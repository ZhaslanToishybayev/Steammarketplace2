# Steam Marketplace Configuration
# Copy this file to .env and update the values
# For Docker: Copy to .env.docker and use docker-compose --env-file .env.docker up

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# MongoDB
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme_in_production
MONGO_DATABASE=steam-marketplace
MONGODB_URI=mongodb://admin:changeme_in_production@mongodb:27017/steam-marketplace?authSource=admin

# Redis
REDIS_PASSWORD=changeme_in_production
REDIS_URL=redis://:changeme_in_production@redis:6379

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================

# JWT Secrets (CRITICAL: Change in production!)
JWT_SECRET=change_this_to_a_random_secure_string_in_production
SESSION_SECRET=3528e219a19da7ee52223423d20a2659f5c3624decd391c3ab15d98725bfd1e8

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================

# Environment
NODE_ENV=development
PORT=3001

# URLs
BASE_URL=http://localhost:3001
CLIENT_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
DEBUG=steam-marketplace:*

# ==============================================================================
# STEAM INTEGRATION (REQUIRED)
# ==============================================================================

# Get from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here
STEAM_CLIENT_ID=your_steam_client_id
STEAM_CLIENT_SECRET=your_steam_client_secret

# ==============================================================================
# STEAM BOTS CONFIGURATION (OPTIONAL)
# ==============================================================================

# Bot 1
STEAM_BOT_1_USERNAME=your_bot_username
STEAM_BOT_1_PASSWORD=your_bot_password
STEAM_BOT_1_SHARED_SECRET=your_shared_secret
STEAM_BOT_1_IDENTITY_SECRET=your_identity_secret

# Bot 2 (add more as needed)
# STEAM_BOT_2_USERNAME=...
# STEAM_BOT_2_PASSWORD=...
# STEAM_BOT_2_SHARED_SECRET=...
# STEAM_BOT_2_IDENTITY_SECRET=...

# ==============================================================================
# MONITORING & TRACKING
# ==============================================================================

# Sentry Error Tracking (Optional)
# Get from: https://sentry.io
SENTRY_DSN=your_sentry_dsn_here

# ==============================================================================
# PAYMENT PROCESSING (OPTIONAL)
# ==============================================================================

# Stripe (for future payment features)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ==============================================================================
# DOCKER-SPECIFIC SETTINGS
# ==============================================================================

# If using Docker, you can override the above values using environment files
# Example: docker-compose --env-file .env.docker up

# Development Docker Settings
# Set to development to enable hot reload
COMPOSE_PROJECT_NAME=steam-marketplace

# ==============================================================================
# PRODUCTION DEPLOYMENT
# ==============================================================================

# For production deployment, ensure you:
# 1. Change all default passwords
# 2. Generate new JWT secrets
# 3. Set strong SESSION_SECRET
# 4. Enable HTTPS
# 5. Set proper CORS origins
# 6. Enable Sentry error tracking
# 7. Use environment-specific configuration files
# 8. Set up SSL certificates
# 9. Configure rate limiting
# 10. Set up backup strategies
