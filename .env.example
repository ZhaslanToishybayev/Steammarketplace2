# ===========================================
# 🔥 STEAM MARKETPLACE - ENVIRONMENT CONFIG
# ===========================================

# ===========================================
# 🔧 REQUIRED SETTINGS
# ===========================================

# MongoDB Database
# Get free MongoDB at: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb://localhost:27017/steam-marketplace

# JWT Secret (generate a random string)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Session Secret (generate a random string)
SESSION_SECRET=your_super_secret_session_key_here

# ===========================================
# 🌐 APPLICATION SETTINGS
# ===========================================

# Server URL (no trailing slash)
BASE_URL=http://localhost:3001

# Frontend URL (no trailing slash)
CLIENT_URL=http://localhost:3000

# Server Port
PORT=3001

# ===========================================
# 🔑 STEAM INTEGRATION (REQUIRED)
# ===========================================

# Steam API Key
# Get at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# ===========================================
# 🤖 STEAM BOT CONFIGURATION
# ===========================================

# Steam Bot Account #1
# Create a new Steam account and get these values
STEAM_BOT_1_USERNAME=your_bot_username
STEAM_BOT_1_PASSWORD=your_bot_password
STEAM_BOT_1_SHARED_SECRET=your_bot_shared_secret
STEAM_BOT_1_IDENTITY_SECRET=your_bot_identity_secret

# Steam Bot Account #2 (optional, for load balancing)
# STEAM_BOT_2_USERNAME=your_bot2_username
# STEAM_BOT_2_PASSWORD=your_bot2_password
# STEAM_BOT_2_SHARED_SECRET=your_bot2_shared_secret
# STEAM_BOT_2_IDENTITY_SECRET=your_bot2_identity_secret

# ===========================================
# 💳 PAYMENT INTEGRATION (OPTIONAL)
# ===========================================

# Stripe (optional - for payments)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===========================================
# 📧 EMAIL SETTINGS (OPTIONAL)
# ===========================================

# Email configuration for notifications
# EMAIL_SERVICE=gmail
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# ===========================================
# 🔒 SECURITY SETTINGS
# ===========================================

# Node Environment
NODE_ENV=development

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# 📊 MONITORING & LOGGING
# ===========================================

# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# ===========================================
# 🚀 HOW TO GET STEAM BOT CREDENTIALS
# ===========================================

# 1. Create new Steam account at: https://store.steampowered.com/join/
# 2. Add CS2 to library (free)
# 3. Download Steam Mobile app
# 4. Enable Steam Guard Mobile Authenticator
# 5. Get secrets:
#    - Shared Secret: Steam Guard → Recovery Codes → (copy Shared Secret)
#    - Identity Secret: Steam Guard → Authenticator Settings → (copy Identity Secret)
# 6. Set trade URL in bot account: Profile → Trade Offers → Create Trade URL
# 7. Save all credentials to this .env file

# ===========================================
# ✅ QUICK START CHECKLIST
# ===========================================

# [ ] Install MongoDB locally or use MongoDB Atlas
# [ ] Generate JWT_SECRET
# [ ] Generate SESSION_SECRET
# [ ] Get Steam API Key from https://steamcommunity.com/dev/apikey
# [ ] Create Steam Bot Account
# [ ] Get Bot Shared Secret and Identity Secret
# [ ] Copy .env.example to .env
# [ ] Fill in all required values
# [ ] Run: npm install
# [ ] Run: npm run dev
