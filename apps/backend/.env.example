# ============================================
# PRODUCTION CONFIGURATION
# ============================================
# This application uses REAL Steam APIs.
# - Steam OpenID for authentication
# - Steam Community API for inventory
# - steam-user/steam-tradeoffer-manager for trading
# - No mocks are used in production
#
# Bot: Sgovt1 with secrets configured
# ============================================

# Application
NODE_ENV=development
PORT=3001

# PostgreSQL Database Optimization
# TypeORM Auto-Sync: In development (NODE_ENV=development), tables are automatically created/updated on backend startup (synchronize=true). No manual migrations needed. For production, set synchronize=false and use 'npm run db:migrate'.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=steam_user
POSTGRES_PASSWORD=steam_password
POSTGRES_DB=steam_marketplace
DB_POOL_MAX=50
DB_POOL_MIN=10
DB_POOL_IDLE=10000
DB_QUERY_TIMEOUT=30000

# MongoDB Optimization
MONGODB_URI=mongodb://localhost:27017/steam_marketplace
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10

# Redis Optimization
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_KEY_PREFIX=steam-marketplace:
REDIS_SESSIONS_DB=0  # Database 0: User sessions
REDIS_CACHE_DB=1     # Database 1: Application cache
REDIS_QUEUES_DB=2    # Database 2: Bull queue storage
REDIS_THROTTLE_DB=3  # Database 3: Rate limiting/throttling data

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_AUTH_LIMIT=5
THROTTLE_WRITE_LIMIT=30

# Queue Optimization
QUEUE_TRADE_CONCURRENCY=10
QUEUE_INVENTORY_CONCURRENCY=5
QUEUE_PRICE_CONCURRENCY=20

# Monitoring
METRICS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002

# CDN
CDN_URL=https://cdn.example.com
CDN_ENABLED=false

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Steam API Configuration (PRODUCTION)
# =====================================
# IMPORTANT: These are REAL Steam API credentials, NOT mocks
# Get your Steam API key from: https://steamcommunity.com/dev/apikey
# This application connects to Steam's production APIs for:
# - User authentication via Steam OpenID
# - Real-time inventory fetching from Steam Community
# - Live trading via steam-user and steam-tradeoffer-manager
# - Real market pricing from Steam's official endpoints
#
STEAM_API_KEY=your-real-steam-api-key  # Replace with actual Steam API key from https://steamcommunity.com/dev/apikey
STEAM_API_BASE_URL=https://api.steampowered.com
STEAM_INVENTORY_API_URL=https://steamcommunity.com
STEAM_API_RATE_LIMIT_PER_SECOND=5
STEAM_API_RATE_LIMIT_PER_MINUTE=200
STEAM_API_TIMEOUT=10000
STEAM_API_MAX_RETRIES=3
STEAM_API_RETRY_DELAY=1000
STEAM_OAUTH_URL=https://steamcommunity.com/openid
STEAM_REALM=http://localhost:3001
STEAM_RETURN_URL=http://localhost:3001/api/auth/steam/return

# Database Seeding Configuration
# Run 'npm run db:seed' after first backend startup to populate MongoDB with 1000+ CS:GO items and PostgreSQL with price data. Requires valid STEAM_API_KEY. Takes 10-15 minutes.
SEED_MARKET_ITEM_COUNT=1000
SEED_BATCH_SIZE=100
SEED_RATE_LIMIT_DELAY_MS=200
SEED_ENABLE_PROGRESS_LOGGING=true

# Pricing Configuration
STEAM_MARKET_API_URL=https://steamcommunity.com/market
CSGOFLOAT_API_URL=https://csgofloat.com/api/v1
CSGOFLOAT_API_KEY=your-csgofloat-api-key
BUFF163_API_URL=https://buff.163.com/api
BUFF163_API_KEY=your-buff163-api-key
PRICING_CACHE_TTL_SECONDS=1800
PRICE_HISTORY_CACHE_TTL_SECONDS=3600
PRICE_TRENDS_CACHE_TTL_SECONDS=900
PRICE_UPDATE_HIGH_PRIORITY_INTERVAL=15
PRICE_UPDATE_BATCH_SIZE=100
PRICE_API_RATE_LIMIT_STEAM=20
PRICE_API_RATE_LIMIT_CSGOFLOAT=60
PRICE_API_RATE_LIMIT_BUFF163=30
PRICE_API_TIMEOUT=10000
PRICE_API_MAX_RETRIES=3
ENABLE_PRICE_ANOMALY_DETECTION=true
PRICE_ANOMALY_THRESHOLD=2.0

# Inventory Sync Configuration
INVENTORY_SYNC_INTERVAL_MINUTES=30
INVENTORY_SYNC_BATCH_SIZE=10
INVENTORY_CACHE_TTL_SECONDS=1800
ITEM_CACHE_TTL_SECONDS=3600

# Supported Games (App IDs)
STEAM_SUPPORTED_GAMES=730,570,440,252490

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_TTL=60
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info
LOG_FILE_ERROR=logs/error.log
LOG_FILE_COMBINED=logs/combined.log

# External Services
PAYMENT_API_KEY=your-payment-api-key
NOTIFICATION_API_KEY=your-notification-api-key

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://localhost:3000,https://localhost:3001

# WebSocket Configuration
WS_PORT=3001  # Same as backend PORT for unified server
WS_CORS_ORIGIN=http://localhost:3000,http://localhost:3001
WS_PATH=/socket.io  # Default Socket.io path

# Queue
QUEUE_REDIS_URL=redis://localhost:6379
QUEUE_DEFAULT_JOB_TTL=3600000  # Maximum job lifetime in milliseconds (1 hour)
QUEUE_BACKOFF_DELAY_MS=2000    # Initial retry delay in milliseconds (2 seconds)
QUEUE_MAX_RETRIES=3

# Trading Configuration
# =====================
# Bot Activation Requirements:
# - BOT_ENCRYPTION_KEY must be a cryptographically strong random string (minimum 32 characters)
# - Use: openssl rand -hex 32 (generates 64-character hex string)
# - Never reuse encryption keys across environments (dev/staging/prod)
# - STEAM_API_KEY is required for Steam Web API access
# - Bots require valid Steam Guard credentials (sharedSecret, identitySecret)
# - User provided: Bot Sgovt1 with secrets configured
BOT_ENCRYPTION_KEY=REPLACE_WITH_SECURE_KEY_GENERATED_USING_openssl_rand_hex_32  # Generate with: openssl rand -hex 32
MAX_TRADES_PER_HOUR=10
MAX_TRADES_PER_DAY=50
TRADE_POLLING_INTERVAL_MINUTES=2
TRADE_EXPIRY_HOURS=336
TRADE_STALLED_HOURS=24
TRADE_QUEUE_CONCURRENCY=5
TRADE_POLLING_QUEUE_CONCURRENCY=10

# Webhook Configuration
WEBHOOK_TIMEOUT=5000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_SECRET=your-webhook-secret-for-signature-generation
MAX_WEBHOOKS_PER_USER=100

# Bot Configuration
DEFAULT_BOT_MAX_CONCURRENT_TRADES=5
BOT_LOGIN_TIMEOUT=30000
BOT_SESSION_REFRESH_INTERVAL_HOURS=24

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@steam-marketplace.com

# User Module Configuration
USER_PROFILE_CACHE_TTL_SECONDS=300
USER_STATISTICS_CACHE_TTL_SECONDS=600
DEFAULT_USER_LANGUAGE=en
DEFAULT_USER_CURRENCY=USD

# Wallet Configuration
MIN_DEPOSIT_AMOUNT=10
MAX_DEPOSIT_AMOUNT=10000
MIN_WITHDRAWAL_AMOUNT=10
MAX_WITHDRAWAL_AMOUNT=10000
WITHDRAWAL_FEE_PERCENTAGE=2.5
DAILY_WITHDRAWAL_LIMIT=5000
MONTHLY_WITHDRAWAL_LIMIT=50000

# Referral System
REFERRAL_BONUS_AMOUNT=5.00
REFERRAL_REFEREE_BONUS_AMOUNT=2.00
REFERRAL_CODE_LENGTH=10
REFERRAL_EXPIRY_DAYS=365
REFERRAL_REQUIREMENT_FIRST_TRADE=true
REFERRAL_REQUIREMENT_MIN_TRADE_VALUE=10.00

# Crypto Payment Configuration
CRYPTO_PROVIDER=coinbase
CRYPTO_API_KEY=your-crypto-api-key
CRYPTO_API_SECRET=your-crypto-api-secret
CRYPTO_WEBHOOK_SECRET=your-crypto-webhook-secret
CRYPTO_CONFIRMATIONS_REQUIRED=3
SUPPORTED_CRYPTOCURRENCIES=BTC,ETH,USDT,LTC

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# PayPal Configuration
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# Monitoring
ENABLE_REQUEST_LOGGING=true
ENABLE_METRICS=true
METRICS_PORT=9090

# Admin Module Configuration
AUDIT_LOG_RETENTION_DAYS=365
ADMIN_REPORT_EMAIL=admin@steam-marketplace.com
ENABLE_AUTO_AUDIT_LOGGING=true
MAX_DISPUTE_RESOLUTION_DAYS=30
SYSTEM_MAINTENANCE_MODE=false