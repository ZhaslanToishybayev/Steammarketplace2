{
  "name": "steam-marketplace-backend",
  "version": "1.0.0",
  "description": "Backend API for Steam Marketplace built with NestJS",
  "private": true,
  "license": "MIT",
  "overrides": {
    "rxjs": "^7.8.1"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:prod:cluster": "node dist/main --max-old-space-size=4096",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "verify:user-entity": "npm run type-check && npm run lint && echo 'User entity verification passed'",
    "verify:api": "ts-node ../../scripts/verify-api-endpoints.ts",
    "verify:api:verbose": "ts-node ../../scripts/verify-api-endpoints.ts --verbose",
    "verify:cors": "ts-node ../../scripts/verify-cors.ts",
    "verify:all": "npm run verify:api && npm run verify:cors",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "echo 'Note: In development, TypeORM auto-syncs tables on startup (synchronize=true). For production, disable synchronize and run: typeorm migration:generate -n MigrationName && typeorm migration:run' && typeorm migration:run",
    "db:seed": "ts-node src/database/seeds/run-seed.ts",
    "db:verify": "ts-node src/database/scripts/verify-db.ts",
    "db:status": "ts-node src/database/scripts/db-status.ts",
    "phase2:verify": "npm run type-check 2>&1 | tee phase2-type-check-output.txt && echo 'Error count:' && grep -c 'error TS' phase2-type-check-output.txt || echo '0'",
    "phase2:errors:observable": "grep -E '(TS2769|Observable.*is not assignable)' phase2-type-check-output.txt || echo 'No Observable errors found'",
    "phase2:errors:overload": "grep -E '(TS2769|TS2345|No overload matches)' phase2-type-check-output.txt || echo 'No overload errors found'",
    "phase2:check-rxjs": "npm list rxjs && echo '---' && grep -A2 'overrides' package.json",
    "phase2:test-interceptors": "jest --testPathPattern='interceptors/__tests__' --verbose",
    "phase2:full": "npm run phase2:verify && npm run phase2:errors:observable && npm run phase2:errors:overload && npm run build",
    "phase3:count-errors": "npm run type-check 2>&1 | tee phase3-errors.txt && echo 'Total errors:' && grep -c 'error TS' phase3-errors.txt || echo '0'",
    "phase3:categorize": "grep 'error TS' phase3-errors.txt | cut -d':' -f4 | cut -d'(' -f1 | sort | uniq -c | sort -rn || echo 'No errors found'",
    "phase3:fix-imports": "ts-node scripts/phase3-fix-imports.ts",
    "phase3:fix-imports:apply": "ts-node scripts/phase3-fix-imports.ts --apply",
    "phase3:fix-unused": "ts-node scripts/phase3-fix-unused-vars.ts --dry-run",
    "phase3:fix-unused:apply": "ts-node scripts/phase3-fix-unused-vars.ts --apply",
    "phase3:add-assertions": "ts-node scripts/phase3-add-type-assertions.ts --preview",
    "phase3:add-assertions:apply": "ts-node scripts/phase3-add-type-assertions.ts --apply",
    "phase3:verify-build": "npm run build && echo '✅ Build successful!'",
    "phase3:verify-startup": "npm run start:dev & sleep 10 && curl http://localhost:3001/api/health && pkill -f 'nest start'",
    "phase3:full": "npm run phase3:count-errors && npm run phase3:fix-imports:apply && npm run phase3:fix-unused:apply && npm run phase3:verify-build"
  },
  "dependencies": {
    "@liaoliaots/nestjs-redis": "^10.0.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^11.1.9",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/platform-socket.io": "^11.1.9",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^7.1.16",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^5.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.9",
    "axios": "^1.6.2",
    "axios-retry": "^4.0.0",
    "bcrypt": "^5.1.1",
    "bull": "^4.12.0",
    "cache-manager": "^5.2.4",
    "cache-manager-redis-yet": "^4.0.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "coinbase-commerce-node": "^1.0.4",
    "compression": "^1.7.4",
    "crypto": "^1.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "nest-winston": "^1.10.2",
    "openid": "^2.0.12",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-steam": "^1.0.18",
    "pg": "^8.11.3",
    "prom-client": "^15.1.0",
    "redis": "^4.6.11",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.7.4",
    "steam-totp": "^2.1.1",
    "steam-tradeoffer-manager": "^2.10.6",
    "steam-user": "^5.0.0",
    "steamcommunity": "^3.47.0",
    "stripe": "^14.0.0",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.17",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.12",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@types/bcrypt": "^5.0.2",
    "@types/cache-manager": "^4.0.6",
    "@types/compression": "^1.7.4",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^29.5.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-steam": "^1.0.3",
    "@types/pg": "^8.10.7",
    "@types/steam-totp": "^2.1.0",
    "@types/steam-user": "^5.0.0",
    "@types/stripe": "^8.0.0",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.1.1",
    "typescript": "~5.4.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.{js,ts}",
      "!**/*.spec.{js,ts}",
      "!**/node_modules/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": true,
    "printWidth": 80,
    "endOfLine": "lf"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
