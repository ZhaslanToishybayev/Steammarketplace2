{
  "dashboard": {
    "id": null,
    "title": "Steam Marketplace - Security",
    "description": "Security monitoring and events for Steam Marketplace",
    "tags": ["steam", "security", "auth", "monitoring"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Authentication Success Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "steam_marketplace:auth_success_rate_5m",
            "legendFormat": "Success/min",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "pm",
            "decimals": 2,
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 5},
                {"color": "green", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Authentication Failure Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "steam_marketplace:auth_failure_rate_5m",
            "legendFormat": "Failures/min",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "pm",
            "decimals": 2,
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 2},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Active Sessions",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "auth_active_sessions",
            "legendFormat": "Sessions",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          }
        }
      },
      {
        "id": 4,
        "title": "Token Refresh Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "steam_marketplace:token_refresh_rate_5m",
            "legendFormat": "Refreshes/min",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "pm",
            "decimals": 2
          }
        }
      },
      {
        "id": 5,
        "title": "Security Events (Last 1h)",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(increase(security_events_total[1h]))",
            "legendFormat": "Total Events",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0,
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 50}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "High Severity Events",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
        "targets": [
          {
            "expr": "sum(increase(security_events_total{severity=\"high\"}[1h]))",
            "legendFormat": "High",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0,
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "API Rate Limit Hits",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(api_rate_limit_hits_total[5m]))",
            "legendFormat": "Hits/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "decimals": 2,
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Active Users (1h)",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
        "targets": [
          {
            "expr": "steam_marketplace:active_users_1h",
            "legendFormat": "Users",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          }
        }
      },
      {
        "id": 9,
        "title": "Authentication Attempts by Method",
        "type": "timeseries",
        "gridPos": {"h": 9, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "sum(rate(auth_attempts_total[5m])) by (method)",
            "legendFormat": "{{method}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Attempts/sec",
            "min": 0,
            "unit": "reqps"
          }
        ]
      },
      {
        "id": 10,
        "title": "Success vs Failure Rate",
        "type": "timeseries",
        "gridPos": {"h": 9, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "sum(rate(auth_attempts_total{result=\"success\"}[5m]))",
            "legendFormat": "Success",
            "refId": "A"
          },
          {
            "expr": "sum(rate(auth_attempts_total{result=\"failure\"}[5m]))",
            "legendFormat": "Failure",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Attempts/sec",
            "min": 0,
            "unit": "reqps"
          }
        ]
      },
      {
        "id": 11,
        "title": "Security Events by Type",
        "type": "timeseries",
        "gridPos": {"h": 9, "w": 12, "x": 0, "y": 25},
        "targets": [
          {
            "expr": "sum(rate(security_events_total[5m])) by (type)",
            "legendFormat": "{{type}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Events/sec",
            "min": 0,
            "unit": "reqps"
          }
        ]
      },
      {
        "id": 12,
        "title": "Security Events by Severity",
        "type": "timeseries",
        "gridPos": {"h": 9, "w": 12, "x": 12, "y": 25},
        "targets": [
          {
            "expr": "sum(rate(security_events_total[5m])) by (severity)",
            "legendFormat": "{{severity}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Events/sec",
            "min": 0,
            "unit": "reqps"
          }
        ]
      },
      {
        "id": 13,
        "title": "Rate Limit Hits by Endpoint",
        "type": "timeseries",
        "gridPos": {"h": 9, "w": 12, "x": 0, "y": 34},
        "targets": [
          {
            "expr": "sum(rate(api_rate_limit_hits_total[5m])) by (endpoint)",
            "legendFormat": "{{endpoint}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Hits/sec",
            "min": 0,
            "unit": "reqps"
          }
        ]
      },
      {
        "id": 14,
        "title": "Token Refresh Rate",
        "type": "timeseries",
        "gridPos": {"h": 9, "w": 12, "x": 12, "y": 34},
        "targets": [
          {
            "expr": "sum(rate(token_refresh_total[5m])) by (result)",
            "legendFormat": "Refresh - {{result}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Refreshes/sec",
            "min": 0,
            "unit": "reqps"
          }
        ]
      },
      {
        "id": 15,
        "title": "Security Events Log",
        "type": "table",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 43},
        "targets": [
          {
            "expr": "sum(increase(security_events_total[1h])) by (type, severity, source)",
            "legendFormat": "",
            "refId": "A"
          }
        ],
        "columns": [
          {"text": "Type", "value": "Type"},
          {"text": "Severity", "value": "Severity"},
          {"text": "Source", "value": "Source"},
          {"text": "Count", "value": "Count"}
        ]
      }
    ]
  }
}
