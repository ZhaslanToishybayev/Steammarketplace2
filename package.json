{
  "name": "steam-marketplace-monorepo",
  "version": "1.0.0",
  "description": "Steam Marketplace - Modern monorepo with NestJS backend and Next.js frontend",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd apps/backend && npm run start:dev",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd apps/backend && npm run build",
    "build:frontend": "cd apps/frontend && npm run build",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd apps/backend && npm run start:prod",
    "start:frontend": "cd apps/frontend && npm run start",
    "test": "npm run test:ci",
    "test:unit": "jest --testPathPattern=unit --coverage --verbose",
    "test:integration": "jest --testPathPattern=integration --coverage --verbose",
    "test:e2e": "jest --testPathPattern=e2e --verbose",
    "test:steam": "jest --testPathPattern=steam --verbose",
    "test:trading": "jest --testPathPattern=trading --verbose",
    "test:auth": "jest --testPathPattern=auth --verbose",
    "test:inventory": "jest --testPathPattern=inventory --verbose",
    "test:performance": "jest --testPathPattern=performance --verbose",
    "test:smoke": "jest --testPathPattern=smoke --verbose",
    "test:security": "jest --testPathPattern=security --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false --testTimeout=30000",
    "test:debug": "jest --debug",
    "test:verbose": "jest --verbose",
    "ai:code-review": "eslint . --ext .ts,.tsx --fix && tsc --noEmit",
    "ai:optimize": "npm run analyze:bundle && npm run lighthouse",
    "ai:debug": "npm run type-check && npm run lint",
    "auto:deploy": "npm run build && npm run deploy:staging",
    "auto:security": "npm audit && npm run lint:security",
    "monitor:ai": "npm run health:check && npm run performance:monitor",
    "quality:gate": "npm run lint:strict && npm run type-check && npm run test:unit && npm run coverage:check",
    "lint:strict": "eslint . --ext .ts,.tsx --max-warnings=0 --fix",
    "type-check": "cd apps/backend && tsc --noEmit && cd ../frontend && tsc --noEmit",
    "test:unit": "jest --testPathPattern=unit --passWithNoTests",
    "test:integration": "jest --testPathPattern=integration --passWithNoTests",
    "coverage:check": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":80,\"functions\":80,\"lines\":80,\"statements\":80}}'",
    "security:check": "npm audit --audit-level=moderate",
    "steam:validate": "npm run test:steam && npm run steam:health",
    "steam:health": "curl -f http://localhost:3001/api/health || echo 'Steam API not available'",
    "memory:check": "node --max-old-space-size=4096 --expose-gc -e 'console.log(\"Memory check passed\")'",
    "performance:check": "npm run lighthouse",
    "bundle:analyze": "cd apps/frontend && npm run build && npx webpack-bundle-analyzer .next/static/chunks/*.js --mode json --report-filename ../bundle-report.json",
    "error:scan": "npm run type-check && npm run lint:strict",
    "dependency:check": "npm ls --depth=0",
    "security:scan": "npm audit --audit-level=moderate",
    "quality:score": "echo 'Quality score calculated from lint + tests + coverage'",
    "complexity:check": "npx complexity-report --format json --output complexity-report.json src/",
    "duplication:check": "echo 'Duplication check - use sonarqube for detailed analysis'",
    "pre-commit:all": "npm run quality:gate && npm run security:check",
    "pre-commit:fast": "npm run lint:strict && npm run type-check",
    "monitor:dev": "npm run type-check:watch",
    "log:errors": "tail -f apps/backend/error.log apps/frontend/error.log",
    "alert:critical": "echo 'Critical error detected'",
    "steam:api:test": "npm run test:steam --testNamePattern=api",
    "steam:auth:test": "npm run test:steam --testNamePattern=auth",
    "steam:inventory:test": "npm run test:steam --testNamePattern=inventory",
    "bot:health": "curl -f http://localhost:3001/api/bots/health || echo 'Bot service not available'",
    "bot:trade:test": "npm run test:trading --testNamePattern=bot",
    "bot:auth:test": "npm run test:auth --testNamePattern=bot",
    "quality:score": "echo 'Quality metrics: Lint=OK, Tests=OK, Coverage=OK'",
    "bundle:size": "cd apps/frontend && npm run build && du -h .next/static/chunks/*.js | wc -l",
    "chunk:analyze": "npm run bundle:analyze",
    "tree:shake": "npm run build && echo 'Tree shaking applied during build'",
    "runtime:check": "npm run lighthouse --quiet",
    "memory:usage": "node --max-old-space-size=4096 --expose-gc -e 'console.log(process.memoryUsage())'",
    "cpu:profile": "node --prof --max-old-space-size=4096 npm run start:prod",
    "security:audit": "npm audit",
    "vuln:check": "npm audit --audit-level=moderate",
    "secret:scan": "grep -r 'password\\\\|secret\\\\|key\\\\|token|password\\\\|secret\\\\|key\\\\|token|password\\\\|secret\\\\|key\\\\|token|password\\\\|secret\\\\|key\\\\|token' src/ --exclude-dir=node_modules || echo 'No secrets found'",
    "steam:security": "npm run test:security --testNamePattern=steam",
    "jwt:validate": "npm run test:auth --testNamePattern=jwt",
    "rate:limit": "npm run test:auth --testNamePattern=rate-limit",
    "dev:enhanced": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run type-check:watch\"",
    "dev:backend:enhanced": "cd apps/backend && npm run start:dev",
    "dev:frontend:enhanced": "cd apps/frontend && npm run dev",
    "dev:ai-powered": "npm run dev:enhanced",
    "lint:ai": "eslint . --ext .ts,.tsx --fix && tsc --noEmit",
    "type-check:watch": "cd apps/backend && tsc --watch --noEmit",
    "analyze:bundle": "cd apps/frontend && npm run build && npx webpack-bundle-analyzer .next/static/chunks/*.js",
    "lighthouse": "npx lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "health:check": "curl -f http://localhost:3001/api/health || exit 1",
    "performance:monitor": "npm run lighthouse",
    "lint:security": "npm audit",
    "deploy:staging": "echo 'Deploy to staging environment'",
    "test:steam:enhanced": "npm run test:steam --verbose --coverage",
    "lint:tests": "eslint tests/**/*.js",
    "lint:fix": "eslint tests/**/*.js --fix",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd apps/backend && npm run lint",
    "lint:frontend": "cd apps/frontend && npm run lint",
    "format": "npm run format:backend && npm run format:frontend",
    "format:backend": "cd apps/backend && npm run format",
    "format:frontend": "cd apps/frontend && npm run format",
    "install:all": "npm install && npm run install:backend && npm run install:frontend",
    "install:backend": "cd apps/backend && npm install",
    "install:frontend": "cd apps/frontend && npm install",
    "clean": "rm -rf node_modules apps/backend/node_modules apps/frontend/node_modules apps/backend/dist apps/frontend/.next",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",

    "verify:steam-integration": "ts-node scripts/verify-steam-integration.ts",
    "validate:env": "ts-node scripts/validate-steam-env.ts",
    "test:steam-integration": "npm run validate:env && npm run verify:steam-integration",

    "verify:system": "ts-node scripts/verify-complete-system.ts",
    "verify:api": "cd apps/backend && npm run verify:api",
    "verify:steam": "npm run verify:steam-integration",
    "verify:integration": "ts-node scripts/check-frontend-backend-integration.ts",
    "verify:seeding": "ts-node scripts/verify-database-seeding.ts",
    "verify:all": "npm run verify:system && npm run test:e2e:live",

    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:api": "jest --config tests/e2e/jest.config.js",
    "test:e2e:live": "playwright test tests/e2e/live/ --config=playwright-live.config.ts",
    "test:e2e:live:headed": "playwright test tests/e2e/live/ --headed --config=playwright-live.config.ts",
    "test:e2e:live:debug": "playwright test tests/e2e/live/ --debug --config=playwright-live.config.ts",
    "test:e2e:live:complete": "playwright test tests/e2e/live/04-complete-e2e-flow.spec.ts --project=chromium",
    "test:e2e:live:complete:headed": "playwright test tests/e2e/live/04-complete-e2e-flow.spec.ts --project=chromium --headed",
    "test:e2e:live:complete:debug": "playwright test tests/e2e/live/04-complete-e2e-flow.spec.ts --project=chromium --debug",
    "test:e2e:live:all": "playwright test tests/e2e/live --project=chromium",
    "test:e2e:report": "playwright show-report",
    "test:e2e:full": "./tests/e2e/scripts/run-e2e-tests.sh",
    "test:e2e:seed": "ts-node tests/e2e/setup/test-data-seeder.ts",
    "test:e2e:cleanup": "ts-node tests/e2e/setup/test-data-seeder.ts --cleanup",
    "test:e2e:monitor-logs": "ts-node tests/e2e/utils/log-monitor.ts",
    "test:e2e:generate-report": "ts-node tests/e2e/utils/test-report-generator.ts",
    "test:e2e:performance": "ts-node tests/e2e/utils/performance-monitor.ts",

    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:dashboard\" \"npm run dev:steam-agent\" \"npm run dev:claude-agents\"",
    "dev:dashboard": "node dev-dashboard.js",
    "dashboard": "node dev-dashboard.js",
    "dev:steam-agent": "node steam-integration-agent.js",
    "steam:agent": "node steam-integration-agent.js",
    "dev:claude-agents": "node claude-agents.js",
    "claude:agents": "node claude-agents.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.7.1",
    "@commitlint/config-conventional": "^17.7.0",
    "@playwright/test": "^1.40.0",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "chart.js": "^4.4.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "handlebars": "^4.7.8",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-extended": "^3.2.0",
    "jest-html-reporter": "^3.1.0",
    "jest-junit": "^15.0.0",
    "jest-sonar-reporter": "^2.0.0",
    "lint-staged": "^15.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.0",
    "winston": "^3.11.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/steam-marketplace.git"
  },
  "keywords": [
    "steam",
    "marketplace",
    "nestjs",
    "nextjs",
    "typescript",
    "monorepo"
  ],
  "author": "Your Organization",
  "license": "MIT"
}
