{
  "name": "steam-marketplace",
  "version": "2.0.0",
  "description": "Professional Steam Marketplace - Modern Tech Stack",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "passport": "^0.7.0",
    "passport-steam": "^1.0.17",
    "mongoose": "^8.0.3",
    "redis": "^4.6.11",
    "ioredis": "^5.3.2",
    "stripe": "^14.7.0",
    "socket.io": "^4.7.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "axios": "^1.6.2",
    "uuid": "^9.0.1",
    "nanoid": "^5.0.4",
    "bullmq": "^4.12.0",
    "bull": "^4.12.0",
    "dotenv": "^16.3.1",
    "steam-user": "^4.28.6",
    "steam-tradeoffer-manager": "^2.10.8",
    "steam-totp": "^2.1.1",
    "csgo": "^1.4.1",
    "steam-market-api": "^1.3.4",
    "@sentry/node": "^7.81.1",
    "@sentry/integrations": "^7.81.1",
    "compression": "^1.7.4",
    "express-validator": "^7.0.1",
    "cookie-parser": "^1.4.6",
    "express-async-errors": "^3.1.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/passport": "^1.0.16",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@types/cookie-parser": "^1.4.6",
    "@types/compression": "^1.7.5",
    "@types/jest": "^29.5.8",
    "typescript": "^5.3.3",
    "tsx": "^4.6.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "docker": "^0.2.14"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
